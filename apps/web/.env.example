# Vercel AI Gateway
AI_GATEWAY_API_KEY=

# Local PostgreSQL via kind cluster
DATABASE_URL=postgresql://lattik:lattik-local@localhost:5432/lattik_studio

# Must be https://lattik-studio.dev for local dev (portless --tld dev)
AUTH_URL=https://lattik-studio.dev

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google Cloud Console > APIs & Services > Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Iceberg REST catalog (local dev)
ICEBERG_REST_URL=http://localhost:8181

# Gitea (local dev)
GITEA_URL=http://localhost:3300
# Run `pnpm gitea:start` to launch Gitea, then `pnpm gitea:init-logs` and copy
# the value from the `GITEA_TOKEN=...` line printed by the gitea-init job.
GITEA_TOKEN=
GITEA_ORG=lattik
GITEA_REPO=pipelines
# Generate with: openssl rand -hex 32
GITEA_WEBHOOK_SECRET=

# Shared secret for the Lattik Table commit API. Spark batch drivers and the
# backfill driver authenticate with this via `Authorization: Bearer ...`.
# Must match the LATTIK_API_TOKEN key in the `lattik-api-credentials` secret
# in the `workloads` namespace (k8s/spark-rbac.yaml).
# Generate with: openssl rand -hex 32
LATTIK_API_TOKEN=
