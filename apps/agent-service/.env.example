# Agent-service-specific overrides. Shared dev creds (AI Gateway key,
# Gitea token, DATABASE_URL, etc.) are NOT duplicated here — the
# `preview` and `dev` scripts load `apps/web/.env` first via Node's
# `--env-file-if-exists=../web/.env` flag. Anything below overrides the
# values from there.

# HTTP port the agent-service listens on. The web app's
# /api/agent-proxy/* routes proxy to localhost:$PORT.
PORT=3939

# Trusted-client auth: in dev we accept the X-Client-Id / X-User-Id
# headers from the web app without a Vercel OIDC token. Production sets
# neither and uses real OIDC instead.
LATTIK_DEV_AUTH_BYPASS=1
LATTIK_DEV_TRUSTED_CLIENTS=web
